phishjamexplorer.com, www.phishjamexplorer.com {
	root * /srv/phstats
	file_server

	encode gzip zstd

	header {
		Cache-Control "public, max-age=3600"
	}

	# SPA fallback - serve index.html for all routes
	try_files {path} /index.html
}
