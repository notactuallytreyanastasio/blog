bobbby.online, www.bobbby.online {
	reverse_proxy app:4000

	encode gzip zstd

	header {
		# WebSocket support (LiveView)
		X-Forwarded-Proto {scheme}
	}
}

gifmaker.bobbby.online {
	reverse_proxy nathan:4001

	encode gzip zstd

	header {
		# WebSocket support (LiveView)
		X-Forwarded-Proto {scheme}
	}
}

deciduous.dev, www.deciduous.dev {
	root * /srv/deciduous
	file_server

	encode gzip zstd

	header {
		Cache-Control "public, max-age=3600"
	}
}

donny.bobbby.online {
