bobbby.online, www.bobbby.online {
	encode gzip zstd

	header {
		# WebSocket support (LiveView)
		X-Forwarded-Proto {scheme}
		# Disable HTTP/3 advertisement — clears Safari's cached alt-svc
		alt-svc "clear"
	}

	# The Claude Arena — LIVE. /arena/play/* stays a static snapshot (the
	# in-browser replay client, kept fresh by the soldat repo's
	# arena-live/publish.mjs -> /opt/arena/play, mounted at /srv/arena);
	# everything else under /arena/* proxies to the live watcher daemon in
	# the `soldat` container (handle_path strips the /arena prefix —
	# watch.mjs serves the site at /). The watcher sends no-store itself;
	# no cache headers here so the dashboards' 5s polls stay fresh.
	redir /arena /arena/ 308
	redir /arena/play /arena/play/ 308
	# Online 1v1 game server (soldat repo packages/server, supervised inside
	# the soldat container on :8902). Plain `handle` (no path strip) BEFORE
	# the /arena/* handlers; the WebSocket upgrade passes through natively.
	handle /arena/ws {
		reverse_proxy soldat:8902
	}
	handle_path /arena/play/* {
		root * /srv/arena/play
		file_server
		header Cache-Control "public, max-age=60"
	}
	handle_path /arena/* {
		reverse_proxy soldat:8901
	}

	# Everything else: the Phoenix app.
	handle {
		reverse_proxy app:4000 {
			# Forward real client IP from Cloudflare to Phoenix
			header_up X-Real-IP {http.request.header.CF-Connecting-IP}
			header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
		}
	}
}

